# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/byteall
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5433/byteall_test

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp-password
SMTP_FROM=ByteAll <noreply@example.com>

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Admin panel session secret (required)
SESSION_SECRET=<long-random-string>

# App
PORT=3000
NODE_ENV=development
