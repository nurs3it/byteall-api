{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@tiptap/core": ["./node_modules/@tiptap/core"],
      "@tiptap/react": ["./node_modules/@tiptap/react"],
      "@tiptap/starter-kit": ["./node_modules/@tiptap/starter-kit"],
      "@tiptap/extension-underline": ["./node_modules/@tiptap/extension-underline"],
      "@tiptap/extension-image": ["./node_modules/@tiptap/extension-image"],
      "@tiptap/extension-link": ["./node_modules/@tiptap/extension-link"]
    }
  },
  "include": ["src"]
}
